# Frontend environment (copy to frontend/.env, then restart `npm run dev`).
# These are read by Vite at build time (import.meta.env.VITE_*).

# The deployed WillChain contract address. Get it after deploying with:
#   python ../scripts/verify_deploy.py <tx_hash>
# Live Bradbury deployment of this contract:
VITE_WILLCHAIN_CONTRACT_ADDRESS=0x8aBeD63ff6D9E07d7E1d404A17Fd71BE1fDE59fd

# Which network the frontend talks to (localnet | studionet | testnet_bradbury | testnet_asimov).
VITE_WILLCHAIN_CHAIN=testnet_bradbury
