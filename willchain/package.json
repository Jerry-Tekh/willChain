{
  "name": "willchain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Deploy scripts for the WillChain Intelligent Contract. See frontend/package.json for the dApp UI's own dependencies (kept separate on purpose).",
  "scripts": {
    "deploy": "node scripts/deploy.mjs",
    "deploy:bradbury": "node scripts/deploy.mjs --chain testnet_bradbury",
    "deploy:studionet": "node scripts/deploy.mjs --chain studionet",
    "deploy:py": "python scripts/deploy_py.py --chain testnet_bradbury",
    "verify": "python scripts/verify_deploy.py"
  },
  "dependencies": {
    "genlayer-js": ">=1.1.8"
  }
}
