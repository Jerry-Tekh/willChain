# --- Root-level (used by scripts/deploy.mjs and scripts/deploy_py.py) ---
# Needed to deploy to a real network (testnet_bradbury / testnet_asimov).
# Studio/localnet auto-provision accounts for you.
#
# The deploy scripts read PRIVATE_KEY first (this is the primary name), then
# fall back to ACCOUNT_PRIVATE_KEY_1. Supply ONE funded testnet account:
PRIVATE_KEY=
ACCOUNT_ADDRESS=

# Legacy / alternative names still accepted by the deploy scripts and by
# gltest.config.yaml's testnet_asimov network:
ACCOUNT_PRIVATE_KEY_1=
ACCOUNT_PRIVATE_KEY_2=
ACCOUNT_PRIVATE_KEY_3=

# --- Frontend (copy this section into frontend/.env) ---
# Fill in after running a deploy script.
VITE_WILLCHAIN_CONTRACT_ADDRESS=
VITE_WILLCHAIN_CHAIN=testnet_bradbury
