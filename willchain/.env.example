# --- Root-level (used by scripts/deploy.mjs and scripts/deploy_py.py) ---
# Only needed for testnet_asimov (real funded accounts). Studio/localnet
# auto-provision accounts for you.
ACCOUNT_PRIVATE_KEY_1=
ACCOUNT_PRIVATE_KEY_2=
ACCOUNT_PRIVATE_KEY_3=

# --- Frontend (copy this section into frontend/.env) ---
# Fill in after running a deploy script.
VITE_WILLCHAIN_CONTRACT_ADDRESS=
VITE_WILLCHAIN_CHAIN=studionet
